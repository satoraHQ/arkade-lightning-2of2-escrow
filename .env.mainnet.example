# MAINNET config for the whole stack.
#
#   cp .env.mainnet.example .env
#
# The server reads this file and the frontends read network-specific config
# (network, hrp, explorer URLs) from the server's /healthz, so this is the
# single place to switch networks.
#
# ⚠️  This is a PoC — NOT hardened for real funds. Browser keys live in
#     localStorage unencrypted, the server hot key sits in every cooperative
#     leaf, and offer/contract state is in-memory. Read the README trust model
#     before pointing this at mainnet with real value.

# Arkade ASP endpoint. Replace with the real mainnet ASP URL.
ARK_SERVER_URL=https://arkade.computer

# Satora (LN <-> Arkade swap router). Replace with the mainnet router URL.
SATORA_API_URL=https://api.satora.io

# Network name. One of: bitcoin | testnet | signet | mutinynet | regtest
# `bitcoin` is mainnet.
NETWORK=bitcoin

# Block explorers the frontends link to (served via /healthz).
ARK_EXPLORER_URL=https://arkade.space
L1_EXPLORER_URL=https://mempool.space

# HTTP listen port for the Peach-style server.
PORT=3210

# Path to the peach server's persisted hot key (32-byte raw secret). Created
# on first start if absent. KEEP IT BACKED UP — the server is in every
# cooperative leaf; losing this key means every active escrow is unspendable
# until the CSV escape elapses. On mainnet, back this up off-box.
PEACH_SECRET_KEY_PATH=./peach-server.key

# Note: offer/contract state lives in-memory and is lost on restart.
# Not acceptable for mainnet beyond a demo; swap in sqlite/postgres first.

# Peach commission, basis points (10 = 0.1%).
FEE_BPS=0

# Ark address that receives the Peach fee output on every release tx.
# Auto-derived on startup from a DefaultVtxo(peachKey, aspKey) if not set.
# PEACH_FEE_ARK_ADDRESS=

# Note on the escrow CSV timelock:
# Real Peach mainnet has only one timeout — `[peach]` alone after
# ~30 days CSV. We mirror that on Ark using the ASP's
# `unilateralExitDelay` (~30 days on mainnet); not configurable
# because the ASP rejects any unilateral-exit closure shorter than
# its advertised value. Seller has no unilateral exit, same as real
# Peach — recovery relies on the pre-signed cooperative refund tx.
