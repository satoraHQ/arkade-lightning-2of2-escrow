# Mutinynet (signet testnet) config for the whole stack. This is the PoC default.
#
#   cp .env.mutinynet.example .env
#
# `just server` does this for you on first run. The server reads this file and
# the frontends read network-specific config (network, hrp, explorer URLs) from
# the server's /healthz, so this is the single place to switch networks.
#
# For mainnet, start from .env.mainnet.example instead.

# Arkade ASP endpoint.
ARK_SERVER_URL=https://mutinynet.arkade.sh

# Satora (LN <-> Arkade swap router).
SATORA_API_URL=https://mutinynetswap.lendasat.com

# Network name. One of: bitcoin | testnet | signet | mutinynet | regtest
NETWORK=mutinynet

# Block explorers the frontends link to (served via /healthz).
ARK_EXPLORER_URL=https://explorer.mutinynet.arkade.sh
L1_EXPLORER_URL=https://mutinynet.com

# HTTP listen port for the Peach-style server.
PORT=3210

# Path to the peach server's persisted hot key (32-byte raw secret). Created
# on first start if absent. KEEP IT BACKED UP — the server is in every
# cooperative leaf; losing this key means every active escrow is unspendable
# until the CSV escape elapses.
PEACH_SECRET_KEY_PATH=./peach-server.key

# Path to the sqlite database (offer/contract state). Persists across
# restarts; created on first start. Relative to the server's cwd.
DB_PATH=./peach-server.sqlite

# Peach commission, basis points (10 = 0.1%).
FEE_BPS=10

# Ark address that receives the Peach fee output on every release tx.
# Auto-derived on startup from a DefaultVtxo(peachKey, aspKey) if not set.
# PEACH_FEE_ARK_ADDRESS=

# Note on the escrow CSV timelock:
# Real Peach mainnet has only one timeout — `[peach]` alone after
# ~30 days CSV. We mirror that on Ark using the ASP's
# `unilateralExitDelay` (~2 days on mutinynet); not configurable
# because the ASP rejects any unilateral-exit closure shorter than
# its advertised value. Seller has no unilateral exit, same as real
# Peach — recovery relies on the pre-signed cooperative refund tx.
